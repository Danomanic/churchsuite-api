{
  "name": "churchsuite-api",
  "version": "1.0.1",
  "description": "Unofficial TypeScript SDK for the ChurchSuite API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "churchsuite",
    "api",
    "sdk",
    "church",
    "management"
  ],
  "license": "MIT",
  "author": "Daniel Pomfret",
  "repository": {
    "type": "git",
    "url": "https://github.com/Danomanic/churchsuite-api.git"
  },
  "bugs": {
    "url": "https://github.com/Danomanic/churchsuite-api/issues"
  },
  "homepage": "https://github.com/Danomanic/churchsuite-api#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
